HEALTH_RAG_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_nostream
HEALTH_RAG_ASR_APP_KEY=145
HEALTH_RAG_ASR_ACCESS_KEY=
