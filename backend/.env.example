# Django
SECRET_KEY=replace-with-a-local-secret-key
DEBUG=True
ALLOWED_HOSTS=*
JWT_SECRET_KEY=replace-with-a-local-jwt-secret

# Database
# sqlite is recommended for local demo. MySQL can be configured in settings.py compatible fields.
DB_ENGINE=sqlite
USE_REDIS_AS_DB=True

# Redis, used by cache / captcha / channels when available.
REDIS_URL=redis://127.0.0.1:6379/0

# Health RAG LLM
# Local Ollama example:
OLLAMA_BASE_URL=http://localhost:11434
HEALTH_RAG_MODEL_NAME=deepseek-r1:1.5b
HEALTH_RAG_API_KEY=

# OpenAI-compatible API example:
# OLLAMA_BASE_URL=https://api.example.com/v1
# HEALTH_RAG_MODEL_NAME=deepseek-chat
# HEALTH_RAG_API_KEY=sk-xxx

HEALTH_RAG_LLM_TIMEOUT=60
HEALTH_RAG_RECOMMEND_MAX_CHUNKS=600
HEALTH_RAG_EMBEDDING_DIM=512

# Health RAG ASR, optional. Voice input is unavailable until these are configured.
HEALTH_RAG_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
HEALTH_RAG_ASR_APP_KEY=
HEALTH_RAG_ASR_ACCESS_KEY=
HEALTH_RAG_ASR_RESOURCE_ID=volc.bigasr.sauc.duration
HEALTH_RAG_ASR_DEFAULT_LANGUAGE=zh-CN
HEALTH_RAG_ASR_TIMEOUT=30

# Email, optional.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
