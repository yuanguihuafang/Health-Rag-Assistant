# Django 基础配置
SECRET_KEY=django-insecure-0a1bx*8!97l^4z#ml#ufn_*9ut*)zlso$*k-g^h&(2=p@^51md
DEBUG=True
ALLOWED_HOSTS=*

# 数据库配置
# 本地演示建议使用 sqlite；如需 MySQL，可按 settings.py 中兼容字段配置。
DB_ENGINE=sqlite
USE_REDIS_AS_DB=True
DB_NAME=db.sqlite3
# MySQL 配置（DB_ENGINE=mysql 时生效）
# DB_NAME=hertz_server
# DB_USER=root
# DB_PASSWORD=123456
# DB_HOST=localhost
# DB_PORT=3306

# Redis 配置（用于缓存 / 验证码 / Channels，可选）
REDIS_URL=redis://127.0.0.1:6379/0

# Health RAG 大模型配置（OpenAI 兼容接口）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-
LLM_MODEL=deepseek-v4-pro
LLM_TIMEOUT=60

# Health RAG 向量模型配置（OpenAI 兼容接口）
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=sk-
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_TIMEOUT=30

# Health RAG 重新排序配置（OpenAI 兼容接口）
RERANK_ENABLED=True
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1/reranks
RERANK_API_KEY=sk-
RERANK_MODEL=qwen3-rerank
RERANK_TOP_N=20
RERANK_TIMEOUT=30

# 检索配置
RAG_SPARSE_METHOD=bm25
RAG_VECTOR_TOP_K=50
RAG_SPARSE_TOP_K=50
RAG_FUSED_TOP_K=50
RAG_TOP_K=8

# Qdrant 向量库配置
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=health_rag_chunks
QDRANT_TIMEOUT=15


# Query 扩展
RAG_ENABLE_QUERY_EXPANSION=True

# ==================== 跨域配置 ====================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ALL_ORIGINS=True

# ==================== 邮件配置 ====================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=staxmethem@qq.com
EMAIL_HOST_PASSWORD=请填写邮箱SMTP授权码
DEFAULT_FROM_EMAIL=staxmethem@qq.com

# 注册邮箱验证码开关（0=关闭，1=开启）
REGISTER_EMAIL_VERIFICATION=0

# ==================== 验证码配置 ====================
HERTZ_CAPTCHA_LENGTH=4
HERTZ_CAPTCHA_WIDTH=172
HERTZ_CAPTCHA_HEIGHT=54
HERTZ_CAPTCHA_FONT_SIZE=36
HERTZ_CAPTCHA_TIMEOUT=300
HERTZ_CAPTCHA_BACKGROUND_COLOR=#ffffff
HERTZ_CAPTCHA_FOREGROUND_COLOR=#000000
HERTZ_CAPTCHA_NOISE_LEVEL=0.003
HERTZ_CAPTCHA_REDIS_KEY_PREFIX=hertz_captcha:

# ==================== 免登录白名单（正则表达式，逗号分隔） ====================
NO_AUTH_PATTERNS=^/api/auth/login/?$,^/api/auth/register/?$,^/api/auth/email/code/?$,^/api/auth/send-email-code/?$,^/api/auth/password/reset/?$,^/api/auth/password/reset/email/?$,^/api/auth/password/reset/code/?$,^/api/captcha/.*$,^/api/docs/.*$,^/api/redoc/.*$,^/api/schema/.*$,^/admin/.*$,^/static/.*$,^/media/.*$,^/demo/.*$,^/websocket/.*$,^/api/system/.*$,^/api/health-rag/health/?$

